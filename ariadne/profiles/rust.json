{
    "name": "Rust",
    "language_id": "rust",
    "extensions": [".rs"],
    "standard_headers": "use godot::prelude::*;\n",
    "ast_grep_lang": "rust",
    "ast_grep_patterns": {
        "symbol": [
            "fn {symbol_name}($$$) { $$$ }",
            "fn {symbol_name}($$$) -> $$$ { $$$ }",
            "struct {symbol_name} { $$$ }",
            "struct {symbol_name}($$$);",
            "impl {symbol_name} { $$$ }",
            "impl $$$ for {symbol_name} { $$$ }"
        ],
        "all_symbols": [
            ["fn $NAME($$$) { $$$ }", "$NAME"],
            ["fn $NAME($$$) -> $$$ { $$$ }", "$NAME"],
            ["struct $NAME { $$$ }", "$NAME"],
            ["impl $NAME { $$$ }", "$NAME"]
        ]
    },
    "tree_sitter_queries": {
        "skeleton": "(function_item (block) @body)",
        "symbol": "(function_item name: (identifier) @name (#eq? @name \"{symbol_name}\")) @symbol (struct_item name: (type_identifier) @name (#eq? @name \"{symbol_name}\")) @symbol (impl_item type: (type_identifier) @name (#eq? @name \"{symbol_name}\")) @symbol"
    },
    "symbol_capture_name": "symbol",
    "parent_block_types": ["impl_item", "mod_item", "trait_item", "declaration_list"]
}
